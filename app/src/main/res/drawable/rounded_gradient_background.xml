<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 第一层背景是透明的，只有圆角 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" /> <!-- 设置透明背景 -->
            <corners
                android:bottomLeftRadius="0px"
                android:bottomRightRadius="0px"
                android:topLeftRadius="60px"
                android:topRightRadius="60px" />
        </shape>
    </item>

    <!-- 第二层是渐变背景 -->
    <item android:drawable="@drawable/gradient_background" />  <!-- 渐变背景 -->
</layer-list>
